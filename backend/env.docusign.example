# Configurações DocuSign para Extension App Data IO
# Copie este arquivo para .env e preencha com suas credenciais

# Configurações da API DocuSign
DOCUSIGN_API_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_ACCOUNT_ID=your_account_id_here
DOCUSIGN_USER_ID=your_user_id_here
DOCUSIGN_INTEGRATION_KEY=your_integration_key_here
DOCUSIGN_RSA_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----
DOCUSIGN_OAUTH_BASE_PATH=account-d.docusign.com

# Configurações do Extension App
DOCUSIGN_EXTENSION_APP_NAME="Crispy Octo Spoon - Clientes Data IO"
DOCUSIGN_EXTENSION_APP_VERSION=1.0.0

# Configurações de autenticação
DOCUSIGN_AUTH_GRANT_TYPE=urn:ietf:params:oauth:grant-type:jwt-bearer
DOCUSIGN_AUTH_SCOPE=data:read data:write
DOCUSIGN_TOKEN_EXPIRATION=3600
DOCUSIGN_REFRESH_THRESHOLD=300

# Configurações de segurança
ENABLE_RATE_LIMITING=true
MAX_REQUESTS_PER_MINUTE=100
ENABLE_CORS=true
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Configurações de logging
LOG_LEVEL=info
ENABLE_AUDIT_LOG=true
LOG_DOCUSIGN_REQUESTS=true

# Configurações do servidor
PORT=3001
NODE_ENV=development

# Configurações CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002
